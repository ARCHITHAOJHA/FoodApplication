            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('customer_jwt', jsonData.jwt);",
                  "    pm.environment.set('customer_role', jsonData.role);",
                  "    console.log('✅ Customer JWT saved: ' + jsonData.jwt.substring(0, 20) + '...');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullname\": \"John Customer\",\n  \"email\": \"customer@foodzz.com\",\n  \"password\": \"Password123!\",\n  \"role\": \"ROLE_CUSTOMER\"\n}"
