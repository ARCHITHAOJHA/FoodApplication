    {
      "name": "Authentication",
      "item": [
        {
          "name": "Sign Up - Customer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullname\": \"John Doe\",\n  \"email\": \"customer@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"ROLE_CUSTOMER\"\n}"
            },
            "url": {
              "raw": "https://localhost:5454/auth/signup",
              "protocol": "https",
              "host": [
                "localhost"
              ],
              "port": "5454",
              "path": [
                "auth",
                "signup"
              ]
            }
          }
        },
        {
          "name": "Sign Up - Restaurant Owner",
          "request": {
            "method": "POST",
            "header": [
              {
                              "mode": "raw",
                              "raw": "{\n  \"email\": \"customer@example.com\",\n  \"password\": \"password123\"\n}"
                            },
                            "url": {
                              "raw": "{{baseUrl}}/auth/signin",
                              "protocol": "http",
                              "host": ["localhost"],
                              "port": "5454",
                              "path": ["auth", "signin"]
                            },
                            "event": [
                              {
                                "listen": "test",
                                "script": {
                                  "type": "text/javascript",
                                  "exec": [
                                    "const data = pm.response.json();",
                                    "if (data && data.jwt) {",
                                    "  pm.collectionVariables.set('jwt', data.jwt);",
                                    "  pm.environment.set('jwt', data.jwt);",
                                    "}"
                                  ]
                                }
                              }
                            ]
                          }
                        },
                        {
                          "name": "Sign In - Restaurant Owner",
                          "request": {
                            "method": "POST",
                            "header": [
                              {
                                "key": "Content-Type",
                                "value": "application/json"
                              }
                            ],
                            "body": {
                "key": "Content-Type",
                              "raw": "{\n  \"email\": \"owner@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "https://localhost:5454/auth/signup",
              "protocol": "https",
              "host": [
                "localhost"
              ],
              "port": "5454",
              "path": [
                "auth",
                                    "  pm.environment.set('ownerJwt', data.jwt);",
              ]
            }
          }
        },
        {
                            ,
                            "url": {
                              "raw": "{{baseUrl}}/auth/signin",
                              "protocol": "http",
                              "host": ["localhost"],
                              "port": "5454",
                              "path": ["auth", "signin"]
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"owner@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/signin",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "signin"]
            },
            "event": [
              {
                "listen": "test",
                "script": {
                  "type": "text/javascript",
                  "exec": [
                    "const data = pm.response.json();",
                    "if (data && data.jwt) {",
                    "  pm.collectionVariables.set('ownerJwt', data.jwt);",
                    "  pm.environment.set('ownerJwt', data.jwt);",
                    "}"
                  ]
                }
              }
            ]
              "path": [
                "auth",
                "signin"
              ]
            }
          }
        }
      ]
